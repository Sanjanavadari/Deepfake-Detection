# Comma-separated list of allowed frontend origins (required in production)
ALLOWED_ORIGINS=http://localhost:5173

# SQLite database path (use /tmp/predictions.db on Render free tier)
DATABASE_URL=backend/predictions.db

# Path to trained model weights (optional — app falls back to pretrained backbone if missing)
MODEL_PATH=backend/weights/best_model.pth

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Server port (Render injects PORT automatically)
PORT=8001

# Maximum upload sizes for /predict (MB). Defaults are conservative for 512 MB RAM hosts.
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=50

# Per-IP rate limits (slowapi format)
RATE_LIMIT_PREDICT=10/minute
RATE_LIMIT_TRAIN=2/minute
RATE_LIMIT_EVALUATE=10/minute
RATE_LIMIT_HISTORY=30/minute
